  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "populate-menu": "tsx -e \"import { populateMenuDataThreeDaysAhead } from './lib/supabase-setup/db-setup'; populateMenuDataThreeDaysAhead().then(() => console.log('Done')).catch(console.error)\"",
