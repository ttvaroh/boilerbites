{
  "name": "boilerbites",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:release": "expo run:ios --configuration Release",
    "ios:debug": "expo run:ios --configuration Debug",
    "web": "expo start --web",
    "lint": "expo lint",
    "build:ios:production": "eas build --platform ios --profile production",
    "build:ios:preview": "eas build --platform ios --profile preview",
    "populate-menu": "tsx -e \"import { populateMenuDataThreeDaysAhead } from './lib/legacy/db-setup'; populateMenuDataThreeDaysAhead().then(() => console.log('Done')).catch(console.error)\"",
    "populate-today": "tsx -e \"import { updateTodaysMenu } from './lib/legacy/db-setup'; updateTodaysMenu().then(() => console.log('Done')).catch(console.error)\"",
    "populate-menu-v3": "tsx -e \"import { populateMenuDataThreeDaysAheadV3 } from './lib/etl/db-setup-v3'; populateMenuDataThreeDaysAheadV3().then(() => console.log('Done')).catch(console.error)\"",
    "populate-today-v3": "tsx -e \"import { updateTodaysMenuV3 } from './lib/etl/db-setup-v3'; updateTodaysMenuV3().then(() => console.log('Done')).catch(console.error)\""
  },
  "dependencies": {
    "@expo-google-fonts/sora": "^0.4.2",
    "@kingstinct/react-native-healthkit": "^13.1.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@supabase/supabase-js": "^2.76.1",
    "expo": "~54.0.31",
    "expo-apple-authentication": "~8.0.8",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.10",
    "expo-haptics": "^15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.21",
    "expo-splash-screen": "~31.0.13",
    "expo-web-browser": "~15.0.10",
    "nativewind": "^4.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-nitro-modules": "^0.33.7",
    "react-native-reanimated": "^4.1.3",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "^0.5.2",
    "tailwindcss": "^3.4.18"
  },
  "devDependencies": {
    "@types/expo": "^32.0.13",
    "@types/expo__vector-icons": "^9.0.1",
    "@types/node": "^24.9.1",
    "@types/react": "19.1.10",
    "eslint": "^9.39.3",
    "eslint-config-expo": "^10.0.0",
    "typescript": "^5.9.3"
  }
}
